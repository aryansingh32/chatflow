# Core runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
API_KEY=dev-key-change-in-prod
LOG_LEVEL=debug
RATE_LIMIT=100
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:4173,http://localhost:8080

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=automation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PUBLIC_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PUBLIC_PORT=6379

# API public port for docker compose
API_PUBLIC_PORT=3000

# LLMs - OpenRouter defaults
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ENABLE_REASONING=true
CHAT_LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
AI_PLANNER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
AI_SELECTOR_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
AI_RECOVERY_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Browser / execution
MIN_BROWSERS=1
MAX_BROWSERS=3
MAX_CONTEXTS_PER_BROWSER=4
USER_FILE_STORAGE_ROOT=/data/user-files

# Workflow system
WORKFLOW_AUTOLOAD=true

# Optional integrations
CAPTCHA_WEBHOOK_URL=
WHISPER_API_URL=

# Optional observability ports
PROMETHEUS_PUBLIC_PORT=9090
GRAFANA_PUBLIC_PORT=3001
GRAFANA_PASSWORD=admin
